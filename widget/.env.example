# Copy this file to .env and fill in the same values as the main app's
# .env.local (NEXT_PUBLIC_SUPABASE_URL / NEXT_PUBLIC_SUPABASE_ANON_KEY).
# Vite requires the VITE_ prefix to expose env vars to the frontend.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# URL opened by the "Open dashboard" link. Defaults to http://localhost:3000 if unset.
VITE_APP_URL=http://localhost:3000
